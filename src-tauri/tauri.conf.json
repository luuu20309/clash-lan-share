{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Clash LAN Share",
  "version": "0.1.0",
  "identifier": "com.luuu.clash-lan-share",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Clash LAN Share",
        "width": 900,
        "height": 680,
        "minWidth": 780,
        "minHeight": 580,
        "center": true,
        "decorations": false,
        "resizable": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
